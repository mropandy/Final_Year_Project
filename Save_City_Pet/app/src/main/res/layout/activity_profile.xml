<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- 1. 返回按鈕 -->
    <ImageButton
        android:id="@+id/btnArrow"
        android:layout_width="@dimen/back_button_size"
        android:layout_height="@dimen/back_button_size"
        android:layout_margin="16dp"
        android:background="@drawable/white_circle_bg"
        android:src="@drawable/ic_arrow_back"
        android:padding="12dp"
        android:scaleType="fitCenter" />

    <!-- 2. 個人資訊區域 (放在返回按鈕下面) -->
    <LinearLayout
        android:id="@+id/userInfoSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnArrow"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/profileImageLarge"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/profile" />

        <TextView
            android:id="@+id/profileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="User Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textColor="#888888" />
        <TextView
            android:id="@+id/profilePhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="85288888888"
            android:textColor="#888888" />
        <TextView
            android:id="@+id/userId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USERID"
            android:textColor="#888888" />
    </LinearLayout>

    <!-- 3. 底部固定按鈕 -->
    <Button
        android:id="@+id/btnAddMyPet"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="20dp"
        android:layout_alignParentBottom="true"
        android:backgroundTint="#4CAF50"
        android:text="+ 新增私人寵物資料"
        android:textColor="@color/white" />

    <!-- 4. 中間的清單 (放在資訊區和按鈕之間) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/myPetRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/userInfoSection"
        android:layout_above="@id/btnAddMyPet"
        android:padding="16dp" />

</RelativeLayout>
