<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- 1. 底部固定按鈕 (釘在最底) -->
    <Button
        android:id="@+id/btnContact"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:layout_alignParentBottom="true"
        android:backgroundTint="#2196F3"
        android:text="聯絡通報"
        android:textColor="@color/white"
        android:textSize="18sp" />

    <!-- 2. 中間滾動內容 (設定在按鈕上方) -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnContact">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 寵物大圖 -->

            <!-- 文字資訊區 (這裡保留你原本的 TextView 們) -->
            <ImageView
                android:id="@+id/detailPic"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 名字 -->
                <TextView
                    android:id="@+id/detailTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:text="寵物名字" />

                <!-- 案件編號 (補回這個 ID) -->
                <TextView
                    android:id="@+id/tvCaseID"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:text="Case ID: #000" />

                <TextView
                    android:id="@+id/tvDetailInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="年齡 | 性別 | 地區"
                    android:textColor="#666666" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="詳細描述"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#000000" />

                <!-- 詳細描述 (補回這個 ID) -->
                <TextView
                    android:id="@+id/detailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textSize="16sp"
                    android:lineSpacingExtra="5dp"
                    android:textColor="#444444"
                    android:text="這裡會顯示詳細描述內容..." />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 3. 返回按鈕 (💡 關鍵：放在 ScrollView 外面，且在最後面，確保它浮在最上層) -->
    <ImageButton
        android:id="@+id/btnArrow"
        android:layout_width="@dimen/back_button_size"
        android:layout_height="@dimen/back_button_size"
        android:layout_margin="16dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:background="@drawable/white_circle_bg"
        android:src="@drawable/ic_arrow_back"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:elevation="10dp" />

</RelativeLayout>
